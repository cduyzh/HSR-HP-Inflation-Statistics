  "option": [
    {
      "name": "崩裂",
      "desc": "持有【爆裂】的敌方目标被消灭时，使我方全体本场战斗中终结技造成的伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，最多叠加<color=#f29e38ff><unbreak>#2[i]</unbreak></color>次。",
      "param": [
        0.15,
        20
      ]
    },
    {
      "name": "谗慝",
      "desc": "【爆裂】造成的伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，触发时为相邻目标附上1层【爆裂】。",
      "param": [
        0.2
      ]
    },
    {
      "name": "诤语",
      "desc": "我方施放追加攻击击中敌方目标时，有<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>固定概率为目标附上1层【爆裂】。该效果每次攻击对每个敌方目标只能触发1次。",
      "param": [
        0.6
      ]
    }
  ],
