  },
  "option": [
    {
      "name": "诱发",
      "desc": "我方施放战技攻击敌方目标时，有<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>固定概率为目标附上【爆裂】。",
      "param": [
        0.8
      ]
    },
    {
      "name": "殉爆",
      "desc": "敌方目标施放技能时使自身及相邻目标陷入1层【灼伤】。处于【灼伤】状态中的敌方目标受到的伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，该效果最多叠加<color=#f29e38ff><unbreak>#2[i]</unbreak></color>层，且对触发怪诞逸闻效果造成的固定伤害也生效。",
      "param": [
        0.1,
        3
      ]
    },
    {
      "name": "喷溅",
      "desc": "角色施放终结技进行攻击后，行动提前<color=#f29e38ff><unbreak>#3[i]%</unbreak></color>，且造成的伤害提高<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>，持续<color=#f29e38ff><unbreak>#1[i]</unbreak></color>回合。",
      "param": [
        1,
        1,
        0.25
      ]
    }
  ],
