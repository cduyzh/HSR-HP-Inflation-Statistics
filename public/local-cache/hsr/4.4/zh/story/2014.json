{
  "id": 2014,
  "name": "结构规律",
  "buff": {
    "name": null,
    "desc": null,
    "param": []
  },
  "option": [
    {
      "name": "肤廓",
      "desc": "「战意汹涌」期间，我方全体战技不消耗战技点。角色施放战技或终结技后，每击中1个敌方目标获得1层【热潮】，每层使该角色造成的战技和终结技伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，速度提高<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>，最多叠加<color=#f29e38ff><unbreak>#3[i]</unbreak></color>层。",
      "param": [
        0.04,
        0.04,
        10,
        3
      ]
    },
    {
      "name": "圣显",
      "desc": "「战意汹涌」期间我方全体施放战技时消耗等同于自身<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>生命上限的生命值，并在施放战技后回复自身<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>生命上限的生命值。",
      "param": [
        0.2,
        0.2,
        3
      ]
    },
    {
      "name": "空头",
      "desc": "「战意汹涌」期间，敌方目标受到的击破伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，我方角色击破敌方目标弱点时，自身行动提前<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>。",
      "param": [
        0.3,
        0.12,
        3
      ]
    }
  ],
  "sub_option": [
    {
      "name": "战技攻击",
      "desc": "我方施放战技攻击敌方目标后，每击中1个敌方目标，使我方额外积累<color=#f29e38ff><unbreak>#1[i]</unbreak></color>点「战意值」。",
      "param": [
        5
      ]
    },
    {
      "name": "战熄潮平",
      "desc": "战斗开始时，我方施放战技攻击敌方目标后，对每个被攻击的敌方目标造成固定数值的伤害。",
      "param": [
        0.55
      ]
    },
    {
      "name": "战意汹涌",
      "desc": "进入「战意汹涌」时，我方全体行动提前<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，期间敌方目标受到的伤害提高<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>，且我方施放战技攻击敌方目标后，额外对每个被攻击的敌方目标的相邻目标造成固定数值的伤害。",
      "param": [
        1,
        0.5,
        0.55
      ]
    }
  ],
