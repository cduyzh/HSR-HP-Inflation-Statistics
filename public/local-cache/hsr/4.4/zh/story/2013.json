{
  "id": 2013,
  "name": "自证预言",
  "buff": {
    "name": null,
    "desc": null,
    "param": []
  },
  "option": [
    {
      "name": "显化",
      "desc": "「战意汹涌」期间，我方对处于【爆裂】的敌方目标施放战技或发动追加攻击后可以直接触发【爆裂】。",
      "param": [
        2
      ]
    },
    {
      "name": "灵知",
      "desc": "「战意汹涌」期间，敌方目标受到的击破伤害提高<color=#f29e38ff><unbreak>#3[i]%</unbreak></color>，且处于【爆裂】状态的目标被任意单位消灭时会对相邻敌方目标造成<color=#f29e38ff><unbreak>#1[i]</unbreak></color>点无视弱点属性的削韧。",
      "param": [
        10,
        3,
        0.3
      ]
    },
    {
      "name": "神智",
      "desc": "「战意汹涌」期间，我方全体施放战技时消耗等同于自身当前生命值<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>的生命值，并在施放战技后回复等同于自身生命上限<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>的生命值。",
      "param": [
        0.2,
        0.2,
        2
      ]
    }
  ],
  "sub_option": [
    {
      "name": "终结技/普攻攻击",
      "desc": "我方施放普攻或终结技攻击敌方目标后，每击中1个敌方目标，使我方额外积累<color=#f29e38ff><unbreak>#1[i]</unbreak></color>点「战意值」。",
      "param": [
        3
      ]
    },
    {
      "name": "战熄潮平",
      "desc": "我方施放普攻或终结技攻击敌方目标时，为目标附上【爆裂】，最多叠加<color=#f29e38ff><unbreak>#1[i]</unbreak></color>层。目标的回合开始或被任意单位消灭时，根据【爆裂】层数对该目标造成真实伤害。",
      "param": [
        3,
        0.5
      ]
    },
    {
      "name": "战意汹涌",
      "desc": "进入「战意汹涌」时，立即为我方全体恢复<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>能量，该效果恢复的能量可以超出目标的能量上限。期间敌方目标受到的伤害提高<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>，且触发【爆裂】时会对该目标及其相邻目标造成真实伤害。",
      "param": [
        0.3,
        0.5,
        0.35
      ]
    }
  ],
