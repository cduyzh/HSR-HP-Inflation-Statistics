{
  "id": 2015,
  "name": "叙事分析",
  "buff": {
    "name": null,
    "desc": null,
    "param": []
  },
  "option": [
    {
      "name": "共相",
      "desc": "「战意汹涌」期间，我方全体速度提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，消耗所有【回音】攻击时恢复1个战技点。",
      "param": [
        0.4,
        3
      ]
    },
    {
      "name": "悖论",
      "desc": "我方全体攻击没有对应属性弱点的敌人也能削减韧性，效果等同于原削韧值的<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，无法与其他无视弱点属性削韧效果叠加。「战意汹涌」期间，敌方目标受到的击破伤害提高<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>。",
      "param": [
        0.5,
        0.3,
        3
      ]
    },
    {
      "name": "神谱",
      "desc": "消耗【回音】造成伤害后，我方全体造成的伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，持续<color=#f29e38ff><unbreak>#2[i]</unbreak></color>回合。",
      "param": [
        0.6,
        1
      ]
    }
  ],
  "sub_option": [
    {
      "name": "终结技攻击",
      "desc": "我方施放终结技攻击敌方目标后，每击中1个敌方目标，使我方额外积累<color=#f29e38ff><unbreak>#1[i]</unbreak></color>点「战意值」。",
      "param": [
        5
      ]
    },
    {
      "name": "战熄潮平",
      "desc": "敌方目标被任意单位消灭后，为我方全体附上1层【回音】。",
      "param": []
    },
    {
      "name": "战意汹涌",
      "desc": "进入「战意汹涌」时，消耗所有【回音】，每层【回音】对随机敌方目标造成1次固定数值的伤害。「战意汹涌」期间，敌方目标受到的伤害提高<color=#f29e38ff><unbreak>#3[i]%</unbreak></color>，且被任意单位消灭后额外为我方全体附上1层【回音】，当【回音】叠加至<color=#f29e38ff><unbreak>#1[i]</unbreak></color>层或以上时，消耗所有【回音】，每层【回音】对随机敌方目标造成1次固定数值的伤害。",
      "param": [
        10,
        1.2,
        0.5
      ]
    }
  ],
