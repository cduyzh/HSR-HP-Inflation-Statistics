{
  "id": 2018,
  "name": "五步抑扬",
  "buff": {
    "name": null,
    "desc": null,
    "param": []
  },
  "option": [
    {
      "name": "追想",
      "desc": "「战意汹涌」期间，我方目标施放终结技后使我方全体造成的伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，最多叠加<color=#f29e38ff><unbreak>#2[i]</unbreak></color>层，持续至「战意汹涌」结束。",
      "param": [
        0.15,
        5
      ]
    },
    {
      "name": "犹记",
      "desc": "进入「战意汹涌」时，立即恢复<color=#f29e38ff><unbreak>#1[i]</unbreak></color>个战技点。「战意汹涌」期间，敌方目标受到的持续伤害提高<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>。",
      "param": [
        3,
        0.3,
        1
      ]
    },
    {
      "name": "颖悟",
      "desc": "「战意汹涌」期间，我方全体速度提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，施放战技后为我方全体附上<color=#f29e38ff><unbreak>#2[i]</unbreak></color>层【回音】。",
      "param": [
        0.2,
        1,
        3
      ]
    }
  ],
  "sub_option": [
    {
      "name": "终结技攻击",
      "desc": "我方施放终结技攻击敌方目标后，每击中1个敌方目标，使我方额外积累<color=#f29e38ff><unbreak>#1[i]</unbreak></color>点「战意值」。",
      "param": [
        5
      ]
    },
    {
      "name": "战熄潮平",
      "desc": "敌方目标被任意单位消灭后，为我方全体附上1层【回音】。",
      "param": []
    },
    {
      "name": "战意汹涌",
      "desc": "进入「战意汹涌」时，消耗所有【回音】，每层【回音】对随机敌方目标造成1次固定数值的伤害。「战意汹涌」期间，敌方目标受到的伤害提高<color=#f29e38ff><unbreak>#3[i]%</unbreak></color>，且被任意单位消灭后额外为我方全体附上1层【回音】，当【回音】叠加至<color=#f29e38ff><unbreak>#1[i]</unbreak></color>层或以上时，消耗所有【回音】，每层【回音】对随机敌方目标造成1次固定数值的伤害。",
      "param": [
        10,
        1.2,
        0.5
      ]
    }
  ],
