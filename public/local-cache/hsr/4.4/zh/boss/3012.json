{
  "id": 3012,
  "name": "冥茫冽风",
  "buff": {
    "name": "末法余烬",
    "desc": "拥有<color=#f29e38ff>【坚防守备】</color>的敌方单位被<color=#f29e38ff>弱点击破</color>时，使我方全体解除控制状态、激活终结技并回复生命值。\\n敌方全体受到的忆灵技伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，战技伤害提高<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>。",
    "param": [
      0.1,
      0.3
    ]
  },
  "buff_list1": [
    {
      "name": "披坚执锐",
      "desc": "我方全体造成的物理属性伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，敌方全体的物理属性抗性降低<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>。",
      "param": [
        0.5,
        0.2
      ]
    },
    {
      "name": "蔓草难除",
      "desc": "我方全体施放普攻或战技攻击处于弱点击破状态下的敌人后，使其当前承受的所有持续伤害立即产生相当于原伤害<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>的伤害。",
      "param": [
        0.2
      ]
    },
    {
      "name": "臻冰彻骨",
      "desc": "敌方全体受到的击破伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>。击破敌方弱点后，我方全体速度提高<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>，持续<color=#f29e38ff><unbreak>#3[i]</unbreak></color>回合。",
      "param": [
        0.1,
        0.2,
        2
      ]
    }
  ],
  "buff_list2": [
    {
      "name": "攻无不克",
