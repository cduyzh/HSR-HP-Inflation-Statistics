        0.3,
        0.01,
        0.15
      ]
    },
    {
      "name": "破竹之势",
      "desc": "角色施放终结技时，使自身的弱点击破效率提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，暴击伤害提高<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>，持续<color=#f29e38ff><unbreak>#3[i]</unbreak></color>回合。",
