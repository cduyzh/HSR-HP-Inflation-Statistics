{
  "id": 3009,
  "name": "冽风支配",
  "buff": {
    "name": "末法余烬",
    "desc": "拥有<color=#f29e38ff>【坚防守备】</color>的敌方单位被<color=#f29e38ff>弱点击破</color>时，使我方全体解除控制状态、恢复战技点并激活终结技。\\n我方全体受到的回复量提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>。",
    "param": [
      0.5
    ]
  },
  "buff_list1": [
    {
      "name": "破晓之召",
      "desc": "忆灵的弱点击破效率提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，忆灵造成伤害时无视目标<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>的防御力。",
      "param": [
        0.5,
        0.2
      ]
    },
    {
      "name": "寸草不生",
      "desc": "角色攻击处于弱点击破状态下的敌人后，其当前承受的所有持续伤害立即产生相当于原伤害<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>的伤害，该效果单个回合内每个角色各自最多触发<color=#f29e38ff><unbreak>#2[i]</unbreak></color>次。",
      "param": [
        0.8,
        2
      ]
    },
    {
      "name": "势如破竹",
      "desc": "造成的终结技伤害的暴击伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，对处于弱点击破状态下的敌方目标额外提高<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>。",
      "param": [
        0.3,
        0.3
      ]
    }
  ],
  "buff_list2": [
    {
      "name": "血战狂澜",
