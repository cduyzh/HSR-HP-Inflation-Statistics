{
  "id": 3003,
  "name": "煽动博弈",
  "buff": {
    "name": "末法余烬",
    "desc": "拥有<color=#f29e38ff>【坚防守备】</color>的敌方单位被<color=#f29e38ff>弱点击破</color>时，使我方全体行动提前并恢复战技点。\\n敌方全体受到的追加攻击伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，终结技伤害提高<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>。",
    "param": [
      0.25,
      0.15
    ]
  },
  "buff_list1": [
    {
      "name": "时来运转",
      "desc": "角色造成的追加攻击伤害无视敌方目标<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>的全属性抗性，同时对非弱点目标也能削减韧性，效果等同于原技能削韧值的<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>。",
      "param": [
        0.15,
        0.5
      ]
    },
    {
      "name": "千金一掷",
      "desc": "角色造成的冰属性伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>。",
      "param": [
        0.55
      ]
    },
    {
      "name": "追亡逐北",
      "desc": "角色击破敌方目标弱点时，行动提前<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，该效果每回合最多触发<color=#f29e38ff><unbreak>#2[i]</unbreak></color>次。",
      "param": [
        0.15,
        1
      ]
    }
  ],
  "buff_list2": [
    {
      "name": "寸草不生",
      "desc": "角色攻击处于弱点击破状态下的敌人后，其当前承受的所有持续伤害立即产生相当于原伤害<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>的伤害，该效果单个回合内每个角色各自最多触发<color=#f29e38ff><unbreak>#2[i]</unbreak></color>次。",
      "param": [
        0.8,
        2
      ]
    },
    {
      "name": "牵丝攀藤",
      "desc": "消灭敌方目标后，敌方全体受到的击破伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，最多叠加<color=#f29e38ff><unbreak>#2[i]</unbreak></color>层，该效果对所有新上场的敌人也生效。",
      "param": [
        0.05,
        5
      ]
    },
    {
      "name": "势如破竹",
      "desc": "造成的终结技伤害的暴击伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，对处于弱点击破状态下的敌方目标额外提高<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>。",
      "param": [
        0.3,
        0.3
      ]
    }
  ],
