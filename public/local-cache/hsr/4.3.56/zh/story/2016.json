{
  "id": 2016,
  "name": "三幕架构",
  "buff": {
    "name": null,
    "desc": null,
    "param": []
  },
  "option": [
    {
      "name": "直叙",
      "desc": "「战意汹涌」期间，我方目标造成的持续伤害无视目标<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>的全属性抗性，敌方目标受到持续伤害后，使我方全体造成的持续伤害提高<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>，最多叠加<color=#f29e38ff><unbreak>#3[i]</unbreak></color>层，持续至「战意汹涌」结束。",
      "param": [
        0.2,
        0.01,
        99
      ]
    },
    {
      "name": "互文",
      "desc": "「战意汹涌」期间，我方目标造成的战技伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，攻击陷入特殊<color=#f29e38ff>风化</color>【迷音】的目标时，每层【迷音】额外使战技伤害提高<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>。",
      "param": [
        0.5,
        0.1,
        3
      ]
    },
    {
      "name": "误置",
      "desc": "每层【迷音】使敌方目标受到的伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，「战意汹涌」期间，敌方目标进入战斗时和行动后额外叠加<color=#f29e38ff><unbreak>#2[i]</unbreak></color>层特殊<color=#f29e38ff>风化</color>【迷音】。",
      "param": [
        0.03,
        1,
        3
      ]
    }
  ],
  "sub_option": [
    {
      "name": "触发持续伤害",
      "desc": "敌方目标每次受到持续伤害后，使我方额外积累<color=#f29e38ff><unbreak>#1[i]</unbreak></color>点「战意值」。",
      "param": [
        2
      ]
    },
    {
      "name": "战熄潮平",
      "desc": "敌方目标进入战斗时陷入<color=#f29e38ff><unbreak>#1[i]</unbreak></color>层特殊<color=#f29e38ff>风化</color>【迷音】，行动后陷入<color=#f29e38ff><unbreak>#2[i]</unbreak></color>层【迷音】，每回合开始时受到风属性持续伤害，最多叠加<color=#f29e38ff><unbreak>#3[i]</unbreak></color>层，持续<color=#f29e38ff><unbreak>#4[i]</unbreak></color>回合。",
      "param": [
        1,
        1,
        10,
        3,
        0.6
      ]
    },
    {
      "name": "战意汹涌",
      "desc": "进入「战意汹涌」时使敌方全体陷入<color=#f29e38ff><unbreak>#5[i]</unbreak></color>层特殊<color=#f29e38ff>风化</color>【迷音】，并使其当前承受的所有持续伤害立即产生相当于原伤害<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>的伤害。「战意汹涌」期间敌方目标受到的伤害提高<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>，造成的伤害降低<color=#f29e38ff><unbreak>#3[i]%</unbreak></color>，速度提高<color=#f29e38ff><unbreak>#4[i]%</unbreak></color>。",
      "param": [
        1,
        0.5,
        0.35,
        0.5,
        5
      ]
    }
  ],
