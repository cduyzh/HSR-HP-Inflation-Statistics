  "option": [
    {
      "name": "毁谤",
      "desc": "敌方受到持续伤害时，对相邻目标造成原伤害<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>的同属性持续伤害。",
      "param": [
        0.6
      ]
    },
    {
      "name": "谣诼",
      "desc": "我方攻击敌方目标后，会使目标陷入风化状态，每回合开始时受到固定数值的风属性持续伤害。",
      "param": [
        0.65,
        5,
        3
      ]
    },
    {
      "name": "诋訾",
      "desc": "敌方受到持续伤害时，为当前生命值百分比最低的我方目标恢复等同于生命上限<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>的生命值，并使其行动提前<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>。",
      "param": [
        0.1,
        0.08
      ]
    }
  ],
