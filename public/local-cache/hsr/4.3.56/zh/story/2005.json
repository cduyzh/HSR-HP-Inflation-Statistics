  },
  "option": [
    {
      "name": "追问",
      "desc": "【怪诞逸闻】效果不再需要累计追加攻击造成的伤害值，改为我方每施放<color=#f29e38ff><unbreak>#1[i]</unbreak></color>次追加攻击后触发，并使该效果造成的伤害提高<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>。",
      "param": [
        3,
        0.6
      ]
    },
    {
      "name": "引申",
      "desc": "触发【怪诞逸闻】效果时，同时为我方全体恢复等同于能量上限<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>的能量。该效果恢复的能量可以超出目标的能量上限。",
      "param": [
        0.35
      ]
    },
    {
      "name": "归谬",
      "desc": "我方造成的除追加攻击以外的其他所有类型的伤害也都可以累计等同于原数值<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>的进度。",
      "param": [
        0.18
      ]
    }
  ],
