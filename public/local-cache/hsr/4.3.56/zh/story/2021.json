{
  "id": 2021,
  "name": "无字小说",
  "buff": {
    "name": null,
    "desc": null,
    "param": []
  },
  "option": [
    {
      "name": "狂欢",
      "desc": "「战意汹涌」期间，敌方目标受到的欢愉伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，阿哈时刻的速度额外提高<color=#f29e38ff><unbreak>#2[i]</unbreak></color>点。",
      "param": [
        0.3,
        20,
        0
      ]
    },
    {
      "name": "狂想",
      "desc": "我方目标施放普攻或战技后，获得<color=#f29e38ff><unbreak>#2[i]</unbreak></color>个笑点；「战意汹涌」期间，我方目标造成的伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>。",
      "param": [
        0.5,
        1,
        3
      ]
    },
    {
      "name": "狂斥",
      "desc": "我方目标施放攻击造成击破伤害后，获得<color=#f29e38ff><unbreak>#2[i]</unbreak></color>个笑点；「战意汹涌」期间，敌方目标受到的击破伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>。",
      "param": [
        0.3,
        1,
        5
      ]
    }
  ],
  "sub_option": [
    {
      "name": "获得笑点",
      "desc": "每次获得笑点时，使我方额外积累<color=#f29e38ff><unbreak>#1[i]</unbreak></color>点「战意值」。",
      "param": [
        2
      ]
    },
    {
      "name": "战熄潮平",
      "desc": "关卡拥有特殊的欢愉技，进入阿哈时刻时对随机敌方目标造成<color=#f29e38ff><unbreak>#1[i]</unbreak></color>次虚数属性欢愉伤害。敌方目标被任意目标消灭时，获得<color=#f29e38ff><unbreak>#3[i]</unbreak></color>笑点。",
      "param": [
        15,
        2.5,
        1
      ]
    },
    {
      "name": "战意汹涌",
      "desc": "进入「战意汹涌」时，使阿哈立即获得一个固定计入<color=#f29e38ff><unbreak>#1[i]</unbreak></color>笑点的额外回合，本回合不消耗笑点且造成的欢愉技伤害为原伤害的<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>。「战意汹涌」期间敌方目标受到的伤害提高<color=#f29e38ff><unbreak>#3[i]%</unbreak></color>，并使阿哈时刻的速度提升<color=#f29e38ff><unbreak>#4[i]</unbreak></color>点。",
      "param": [
        20,
        0.5,
        0.5,
        40
      ]
    }
  ],
