  },
  "option": [
    {
      "name": "谣曲",
      "desc": "「战意汹涌」期间，忆灵造成的伤害提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，当忆灵消失时，使忆师行动提前<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>。",
      "param": [
        0.3,
        0.15,
        3
      ]
    },
    {
      "name": "奏雅",
      "desc": "进入「战意汹涌」时，立即恢复<color=#f29e38ff><unbreak>#1[i]</unbreak></color>个战技点。「战意汹涌」期间，敌方目标受到的持续伤害提高<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>。",
      "param": [
        3,
        0.3,
        1
      ]
    },
    {
      "name": "孤韵",
      "desc": "「战意汹涌」期间，我方施放战技攻击敌方目标后，对每个被攻击的敌方目标额外造成等同于原伤害<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>的真实伤害。",
      "param": [
        0.3
      ]
    }
  ],
  "sub_option": [
    {
      "name": "战技攻击",
      "desc": "我方施放战技攻击敌方目标后，每击中1个敌方目标，使我方额外积累<color=#f29e38ff><unbreak>#1[i]</unbreak></color>点「战意值」。",
      "param": [
        5
      ]
    },
    {
      "name": "战熄潮平",
      "desc": "战斗开始时，我方施放战技攻击敌方目标后，对每个被攻击的敌方目标造成固定数值的伤害。",
      "param": [
        0.55
      ]
    },
    {
      "name": "战意汹涌",
      "desc": "进入「战意汹涌」时，我方全体行动提前<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，期间敌方目标受到的伤害提高<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>，且我方施放战技攻击敌方目标后，额外对每个被攻击的敌方目标的相邻目标造成固定数值的伤害。",
      "param": [
        1,
        0.5,
        0.55
      ]
    }
  ],
