{
  "id": 2010,
  "name": "论黄数黑",
  "buff": {
    "name": null,
    "desc": null,
    "param": []
  },
  "option": [
    {
      "name": "噱头",
      "desc": "我方全体击破特攻提高<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>，击破敌方目标时会令敌方全体陷入风化状态，每回合开始时受到固定数值的风属性持续伤害。\\n敌方全体免疫控制类负面状态。",
      "param": [
        0.3,
        0.65,
        5,
        3
      ]
    },
    {
      "name": "醉话",
      "desc": "我方目标施放终结技攻击敌方目标后，若目标当前承受1/2/3种持续伤害状态，则会使其当前承受的每种持续伤害状态立即产生相当于原伤害<color=#f29e38ff><unbreak>#1[i]%</unbreak></color>/<color=#f29e38ff><unbreak>#2[i]%</unbreak></color>/<color=#f29e38ff><unbreak>#3[i]%</unbreak></color>的伤害。",
      "param": [
        0.6,
        1,
        1.5
      ]
    },
    {
      "name": "谣诼",
      "desc": "我方攻击敌方目标后，会使目标陷入风化状态，每回合开始时受到固定数值的风属性持续伤害。",
      "param": [
        0.65,
        5,
        3
      ]
    }
  ],
